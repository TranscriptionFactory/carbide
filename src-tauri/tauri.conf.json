{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "carbide",
  "version": "1.7.0",
  "identifier": "com.carbide.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "svelte-kit sync && pnpm build:excalidraw && pnpm codegen && pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": [
      "excalidraw-dist/*",
      "excalidraw-dist/assets/*",
      "resources/models/**/*",
      "resources/iwe-default-config.toml"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd",
          "mkdn",
          "mdwn",
          "mdx"
        ],
        "name": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": [
          "txt"
        ],
        "name": "Text Document",
        "mimeType": "text/plain",
        "role": "Editor"
      },
      {
        "ext": [
          "canvas"
        ],
        "name": "JSON Canvas",
        "mimeType": "application/json",
        "role": "Editor"
      },
      {
        "ext": [
          "excalidraw"
        ],
        "name": "Excalidraw Drawing",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBEQzFEMzIwMTYxNUQyM0QKUldROTBoVVdJTlBCRFg2a09vL3NlNEVqL1V4dWxtSmdZZEdmTFA0RjRLaFJkVmRRdUp4TG8zWEgK",
      "endpoints": [
        "https://github.com/TranscriptionFactory/carbide/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "carbide",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "dragDropEnabled": false,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: carbide-asset: carbide-plugin:; style-src 'self' 'unsafe-inline'; script-src 'self' blob: carbide-plugin:; worker-src 'self' blob:; connect-src ipc: http://ipc.localhost carbide-asset:; frame-src carbide-plugin: carbide-excalidraw: carbide-asset:"
    }
  }
}