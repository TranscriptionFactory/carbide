{
  "body": {
    "lineHeight": 1.85,
    "maxWidth": "min(85ch, 90%)"
  },
  "headings": {
    "h1": {
      "fontWeight": 700,
      "lineHeight": 1.2,
      "letterSpacing": "-0.01em",
      "marginTop": "calc(var(--editor-spacing) * 1.75)",
      "marginBottom": "calc(var(--editor-spacing) * 0.6)"
    },
    "h2": {
      "fontWeight": 600,
      "lineHeight": 1.3,
      "letterSpacing": "-0.005em",
      "marginTop": "calc(var(--editor-spacing) * 1.4)",
      "marginBottom": "calc(var(--editor-spacing) * 0.5)"
    },
    "h3": {
      "fontWeight": 600,
      "lineHeight": 1.4,
      "letterSpacing": "-0.005em",
      "marginTop": "calc(var(--editor-spacing) * 1.15)",
      "marginBottom": "calc(var(--editor-spacing) * 0.35)"
    },
    "h4": {
      "fontWeight": 600,
      "lineHeight": 1.45,
      "letterSpacing": "0",
      "marginTop": "calc(var(--editor-spacing) * 0.95)",
      "marginBottom": "calc(var(--editor-spacing) * 0.35)"
    },
    "h5": {
      "fontWeight": 500,
      "lineHeight": 1.55,
      "letterSpacing": "0.05em",
      "marginTop": "calc(var(--editor-spacing) * 0.75)",
      "marginBottom": "calc(var(--editor-spacing) * 0.25)"
    },
    "h6": {
      "fontWeight": 500,
      "lineHeight": 1.6,
      "letterSpacing": "0.08em",
      "marginTop": "calc(var(--editor-spacing) * 0.55)",
      "marginBottom": "calc(var(--editor-spacing) * 0.25)"
    }
  }
}
